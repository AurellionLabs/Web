{
  "name": "my-v0-project",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "codegen": "cd indexer && npm run codegen",
    "dev": "next dev",
    "typecheck": "tsc --noEmit",
    "build": "npm run typecheck && next build",
    "build:full": "npx hardhat compile && npm run extract-abis && npm run typecheck && next build",
    "extract-abis": "node scripts/extract-abis.js",
    "deploy": "npx hardhat run scripts/deploy.ts --network baseSepolia",
    "deploy:order-bridge": "npx hardhat run scripts/deploy-order-bridge.ts --network baseSepolia",
    "start": "next start",
    "lint": "next lint",
    "prepare": "husky",
    "format": "prettier . --write",
    "lint-staged": "lint-staged",
    "test:hardhat": "npx hardhat test",
    "test:hardhat:bridge": "npx hardhat test test/OrderBridge.test.ts",
    "test:service:unit": "npx mocha --require ts-node/register --require tsconfig-paths/register test/infrastructure/services/**/*.service.test.ts",
    "test:service:integration": "npx mocha --require ts-node/register --require tsconfig-paths/register test/infrastructure/services/**/*.service.integration.test.ts",
    "test:service:bridge": "npx vitest run test/services/OrderBridgeService.test.ts",
    "test:service": "npm run test:service:unit && npm run test:service:integration",
    "test:repo:unit": "npx mocha --require ts-node/register --require tsconfig-paths/register test/infrastructure/repositories/**/*.unit.test.ts",
    "test:repo:clob": "npx vitest run test/repositories/CLOBRepository.test.ts",
    "test:hooks": "npx vitest run test/hooks/useUnifiedOrder.test.ts",
    "test:vitest": "npx vitest run",
    "test:coverage": "npx vitest run --coverage",
    "test": "npx vitest run",
    "deploy:diamond": "npx hardhat run scripts/deploy-diamond.ts --network baseSepolia",
    "upgrade:diamond": "npx hardhat run scripts/upgrade-diamond.ts --network baseSepolia",
    "test:diamond": "forge test --match-contract DiamondTest -vv",
    "test:e2e": "vitest run --config e2e/vitest.config.ts",
    "test:e2e:fast": "vitest run --config e2e/vitest.config.ts",
    "test:e2e:isolated": "cross-env ISOLATE_TESTS=true vitest run --config e2e/vitest.config.ts",
    "test:e2e:watch": "vitest --config e2e/vitest.config.ts",
    "test:e2e:anvil": "cross-env CHAIN=anvil vitest run --config e2e/vitest.config.ts",
    "test:e2e:verbose": "cross-env VERBOSE=true vitest run --config e2e/vitest.config.ts",
    "test:e2e:coverage": "cross-env VALIDATE_COVERAGE=true FAIL_ON_COVERAGE=true vitest run --config e2e/vitest.config.ts",
    "test:browser": "npx playwright test",
    "test:browser:headed": "npx playwright test --headed",
    "test:browser:ui": "npx playwright test --ui",
    "test:browser:debug": "npx playwright test --debug",
    "generate:abi": "node -r ts-node/register scripts/generate-diamond-abi.ts",
    "verify:deployment": "npx hardhat run scripts/verify-deployment.ts --network baseSepolia",
    "test:deployment": "npx vitest run test/deployment/",
    "test:smoke": "npx vitest run test/deployment/smoke.test.ts",
    "postdeploy:verify": "npm run verify:deployment"
  },
  "lint-staged": {
    "*.{js,ts,jsx,tsx,json,css,md}": "npm run format"
  },
  "dependencies": {
    "@anthropic-ai/claude-code": "^0.2.66",
