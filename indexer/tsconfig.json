{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "declaration": false,
    "sourceMap": true,
    "outDir": "dist",
    "paths": {
      "@/*": ["./*"]
    }
  },
  "include": [
    "src/**/*.ts",
    "ponder.config.ts",
    "ponder.config.generated.ts",
    "ponder.schema.ts",
    "ponder-env.d.ts",
    "resolve-deploy-block.ts",
    "diamond-constants.ts",
    "chain-constants.ts"
  ],
  "exclude": ["node_modules", "dist"]
}
